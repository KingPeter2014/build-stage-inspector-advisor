# .env.development.example
# Local development environment — all services run via docker-compose.test.yml.
# Copy to .env.development and adjust paths as needed.
# No real cloud credentials required.

APP_ENV=development
APP_COMPLEXITY=reference
LOG_LEVEL=DEBUG
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# ── LLM (use WireMock stub or a personal OpenAI key for local testing) ─────────
OPENAI_API_KEY=sk-test-localdev
ANTHROPIC_API_KEY=sk-ant-test-localdev
HUGGINGFACE_TOKEN=hf_test

# ── Vector store (Qdrant via docker-compose.test.yml) ─────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Cache (Redis via docker-compose.test.yml) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Object store (LocalStack via docker-compose.test.yml) ─────────────────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=llmops-test-data
# Point boto3 at LocalStack
AWS_ENDPOINT_URL=http://localhost:4566

# ── LocalStack config for integration tests ────────────────────────────────────
LLMOPS_LOCALSTACK_URL=http://localhost:4566

# ── Observability (local Jaeger + Prometheus from docker-compose.yml) ──────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=llmops-development

# ── LiteLLM gateway ───────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-dev-master-key
LITELLM_PORT=4000

# ── Experiment tracking (local MLflow from docker-compose.yml) ─────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=
WANDB_PROJECT=llmops-dev

# ── Prompt registry ────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-dev
LANGFUSE_SECRET_KEY=sk-lf-dev
LANGFUSE_HOST=http://localhost:3000

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=llmops.ingestion.dev

# RAG behavior (reference defaults)
RAG_RETRIEVAL_MODE=vector       # vector | hybrid | graph_augmented | hybrid_graph
RAG_SECURITY_MODE=none          # none | metadata_filtering | acl_filtering | policy_enforced_acl
GRAPH_ENABLED=false
RERANKER_ENABLED=false

# ── Azure (dev: use personal service principal, NOT shared team credentials) ───
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=           # OK in dev; NEVER set in .env.production
AZURE_OPENAI_ENDPOINT=         # Leave blank to route through WireMock
AZURE_OPENAI_API_KEY=
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_API_KEY=

# ── AWS (dev: use personal IAM user access keys against LocalStack or sandbox) ─
# For LocalStack, the values above (test/test) are already correct.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
OPENSEARCH_ENDPOINT=           # Leave blank to skip OpenSearch in dev

# ── GCP (dev: use personal service account JSON) ──────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/dev-sa-key.json   # gitignored
VERTEX_MODEL_ID=gemini-1.5-pro-002
