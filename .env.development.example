# Local development environment.
# Copy to .env.development and adjust values as needed.

APP_ENV=development
APP_COMPLEXITY=reference
LOG_LEVEL=DEBUG
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# LLM providers
OPENAI_API_KEY=sk-test-localdev
ANTHROPIC_API_KEY=sk-ant-test-localdev
HUGGINGFACE_TOKEN=hf_test

# Vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Cache
REDIS_URL=redis://localhost:6379

# Optional S3-compatible object store for source/storage tests.
# LocalStack uses these placeholder credentials.
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET=llmops-test-data
LLMOPS_LOCALSTACK_URL=http://localhost:4566

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=build-stage-inspector-development

# LiteLLM gateway
LITELLM_MASTER_KEY=sk-dev-master-key
LITELLM_PORT=4000

# Experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=
WANDB_PROJECT=build-stage-inspector-dev

# Prompt registry
LANGFUSE_PUBLIC_KEY=pk-lf-dev
LANGFUSE_SECRET_KEY=sk-lf-dev
LANGFUSE_HOST=http://localhost:3000

# Streams
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=buildstage.ingestion.dev

# RAG behavior
RAG_RETRIEVAL_MODE=vector
RAG_SECURITY_MODE=none
GRAPH_ENABLED=false
RERANKER_ENABLED=false
