# Copy to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars to source control.

project    = "llmops"
env        = "staging"
aws_region = "us-east-1"

# Set after `terraform apply` creates the ECR repo, then re-apply.
# Format: <account>.dkr.ecr.<region>.amazonaws.com/llmops-staging-gateway:<git-sha>
gateway_image    = "REPLACE_WITH_ECR_REPO_URL:latest"
bedrock_model_id = "anthropic.claude-3-5-sonnet-20241022-v2:0"

opensearch_instance_type  = "t3.medium.search"
opensearch_instance_count = 1
opensearch_volume_size_gb = 20

elasticache_node_type = "cache.t4g.micro"

ecs_cpu           = 512
ecs_memory_mb     = 1024
ecs_desired_count = 1

vpc_cidr = "10.0.0.0/16"

tags = {
  project     = "llmops"
  environment = "staging"
  owner       = "ml-platform"
  cost_center = "ai-infra"
}
