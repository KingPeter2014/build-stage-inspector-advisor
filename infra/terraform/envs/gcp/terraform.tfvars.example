# Copy to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars to source control.

project        = "llmops"
env            = "staging"
gcp_project_id = "your-gcp-project-id"
gcp_region     = "us-central1"

# Set after `terraform apply` creates the Artifact Registry, then re-apply.
# Format: us-central1-docker.pkg.dev/<project>/llmops-staging/gateway:<git-sha>
gateway_image = "REPLACE_WITH_AR_IMAGE_URL:latest"
gemini_model  = "gemini-1.5-pro-002"

vector_search_dimensions = 768  # match your embedding model output dim

memorystore_tier    = "BASIC"
memorystore_size_gb = 1

cloud_run_cpu           = "1"
cloud_run_memory        = "1Gi"
cloud_run_min_instances = 1
cloud_run_max_instances = 10

labels = {
  project     = "llmops"
  environment = "staging"
  owner       = "ml-platform"
}
