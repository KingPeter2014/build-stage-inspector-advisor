# Base environment example for the open-source runtime.

APP_ENV=development
APP_COMPLEXITY=reference
LOG_LEVEL=INFO
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# LLM provider keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_TOKEN=hf_...

# Vector store
QDRANT_URL=https://fe4f808f-27d6-4bdd-b403-482c42926700.europe-west6-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=buildstage_documents_development
RAG_API_URL=http://localhost:4000/v1/rag/query
PGVECTOR_DSN=postgresql://user:pass@localhost:5432/buildstage

# Optional S3-compatible object store
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=
S3_BUCKET=buildstage-data-lake

# Prompt registry
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=
WANDB_PROJECT=build-stage-inspector

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=build-stage-inspector
PROMETHEUS_PORT=8000

# LLM gateway
LITELLM_MASTER_KEY=sk-...
LITELLM_PORT=4000

# Streams
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=buildstage.ingestion

# RAG behavior
RAG_RETRIEVAL_MODE=vector
RAG_SECURITY_MODE=none
GRAPH_ENABLED=false
RERANKER_ENABLED=false
