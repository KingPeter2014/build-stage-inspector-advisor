# ── LLM Provider Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_TOKEN=hf_...

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
PGVECTOR_DSN=postgresql://user:pass@localhost:5432/llmops

# ── Feature Store ──────────────────────────────────────────────────────────────
FEAST_REGISTRY_PATH=./storage/feature_store/registry.db

# ── Data Lake / Object Store ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=llmops-data-lake

# ── Prompt Registry (Langfuse) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Experiment Tracking ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
WANDB_API_KEY=
WANDB_PROJECT=llmops-experiments

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=llmops-service
PROMETHEUS_PORT=8000

# ── LLM Gateway (LiteLLM) ────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-...
LITELLM_PORT=4000

# ── Kafka (Event Streams) ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INGESTION=llmops.ingestion

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
MAX_TOKENS=4096
DEFAULT_MODEL=gpt-4o
