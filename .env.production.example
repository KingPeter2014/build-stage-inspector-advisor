# Production environment variable names.
#
# Production values must be injected by the runtime platform or secret manager.
# Do not commit real API keys, object-store credentials, or private endpoints.

APP_ENV=production
APP_COMPLEXITY=regulated-production
LOG_LEVEL=WARNING
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_TOKEN=

# Vector store
QDRANT_URL=https://fe4f808f-27d6-4bdd-b403-482c42926700.europe-west6-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=buildstage_documents_production
RAG_API_URL=https://advisor.your-domain.com/v1/rag/query

# Cache
REDIS_URL=

# Optional S3-compatible object store for source documents and artifacts.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_ENDPOINT_URL=
S3_BUCKET=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=build-stage-inspector-production

# Experiment tracking
MLFLOW_TRACKING_URI=
WANDB_PROJECT=build-stage-inspector-production

# Prompt registry
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# LiteLLM gateway
LITELLM_MASTER_KEY=
LITELLM_PORT=4000

# RAG behavior
RAG_RETRIEVAL_MODE=
RAG_SECURITY_MODE=
GRAPH_ENABLED=false
RERANKER_ENABLED=false
