# .env.production.example
# Production environment.
#
# IMPORTANT RULES:
#   1. This file documents the NAMES of required variables only.
#      Production values are NEVER stored in files or committed to source control.
#   2. Long-lived credentials (client secrets, API keys) must NOT be used.
#      All production cloud access must use Managed Identity / IAM Roles / WIF.
#   3. Values are injected at runtime by the cloud platform:
#        Azure  → Container Apps environment variables populated from Key Vault refs
#        AWS    → ECS Task Definition environment variables from Secrets Manager
#        GCP    → Cloud Run environment variables from Secret Manager
#   4. Only the CI/CD promote_to_production.yml workflow can trigger a production
#      deployment. It requires GitHub Environment protection (required reviewers).

APP_ENV=production
APP_COMPLEXITY=regulated-production
LOG_LEVEL=WARNING
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# ── Auth note ─────────────────────────────────────────────────────────────────
# Production services authenticate via platform identity — do not set these:
#   AZURE_CLIENT_SECRET         → use Managed Identity
#   AWS_ACCESS_KEY_ID           → use ECS task IAM role
#   AWS_SECRET_ACCESS_KEY       → use ECS task IAM role
#   GOOGLE_APPLICATION_CREDENTIALS → use Workload Identity / Service Account binding

# ── Azure (all values populated from Key Vault at runtime) ────────────────────
AZURE_TENANT_ID=               # Set in Container Apps env from Key Vault ref
AZURE_CLIENT_ID=               # Managed Identity client ID (no secret)
AZURE_OPENAI_ENDPOINT=         # https://llmops-production-oai.openai.azure.com/
AZURE_OPENAI_API_KEY=          # Key Vault ref: @Microsoft.KeyVault(...)
AZURE_AI_SEARCH_ENDPOINT=      # https://llmops-production-search.search.windows.net
AZURE_AI_SEARCH_API_KEY=       # Key Vault ref
AZURE_STORAGE_ACCOUNT_NAME=    # Populated by Terraform output
AZURE_RESOURCE_GROUP=          # llmops-production-rg
AZUREML_WORKSPACE_NAME=        # llmops-production-aml
AZURE_APPINSIGHTS_CONNECTION_STRING=  # Key Vault ref
AZURE_REDIS_URL=                # Key Vault ref (rediss://...)
AZURE_CONTENT_SAFETY_ENDPOINT= # Key Vault ref
AZURE_CONTENT_SAFETY_KEY=      # Key Vault ref

# ── AWS (all values come from Secrets Manager or task definition env) ──────────
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
OPENSEARCH_ENDPOINT=           # Secrets Manager or env var from Terraform output
AWS_REDIS_URL=                  # Secrets Manager
S3_BUCKET=                      # Terraform output injected at deploy time

# ── GCP (all values from Secret Manager or Cloud Run env) ─────────────────────
GCP_PROJECT_ID=                # your-gcp-project-production
GCP_REGION=us-central1
VERTEX_MODEL_ID=gemini-1.5-pro-002
GCS_BUCKET=                    # Terraform output
GCP_REDIS_URL=                  # Secret Manager ref
PERSPECTIVE_API_KEY=           # Secret Manager ref

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=   # Production collector endpoint
OTEL_SERVICE_NAME=llmops-production

# RAG behavior
# Use acl_filtering or policy_enforced_acl for corpora with per-user/group access rules.
RAG_RETRIEVAL_MODE=            # vector | hybrid | graph_augmented | hybrid_graph
RAG_SECURITY_MODE=             # metadata_filtering | acl_filtering | policy_enforced_acl
GRAPH_ENABLED=false            # true when using graph_augmented / hybrid_graph
RERANKER_ENABLED=false

# ── LiteLLM (OSS stack only) ──────────────────────────────────────────────────
LITELLM_MASTER_KEY=            # Secrets Manager / Key Vault ref
