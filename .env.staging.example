# Shared staging environment.
# Copy to .env.staging or inject equivalent values through CI/deployment secrets.

APP_ENV=staging
APP_COMPLEXITY=starter-production
LOG_LEVEL=INFO
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# LLM providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_TOKEN=

# Vector store
QDRANT_URL=https://fe4f808f-27d6-4bdd-b403-482c42926700.europe-west6-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=buildstage_documents_staging
RAG_API_URL=https://advisor.your-domain.com/v1/rag/query

# Cache
REDIS_URL=redis://staging-redis.your-domain.com:6379

# Optional object store for staged source documents and artifacts.
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=
S3_BUCKET=buildstage-staging-data

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-staging.your-domain.com:4317
OTEL_SERVICE_NAME=build-stage-inspector-staging

# Experiment tracking
MLFLOW_TRACKING_URI=https://mlflow-staging.your-domain.com
WANDB_PROJECT=build-stage-inspector-staging

# LiteLLM gateway
LITELLM_MASTER_KEY=
LITELLM_PORT=4000

# Streams
KAFKA_BOOTSTRAP_SERVERS=kafka-staging.your-domain.com:9092
KAFKA_TOPIC_INGESTION=buildstage.ingestion.staging

# RAG behavior
RAG_RETRIEVAL_MODE=hybrid
RAG_SECURITY_MODE=metadata_filtering
GRAPH_ENABLED=false
RERANKER_ENABLED=false
