# .env.staging.example
# Shared staging environment — cloud infrastructure exists but uses non-prod tiers.
# Copy to .env.staging (gitignored). In CI, values are injected from GitHub
# Environment secrets scoped to the "staging" GitHub Environment.
# Staging credentials must NEVER have production write permissions.

APP_ENV=staging
APP_COMPLEXITY=starter-production
LOG_LEVEL=INFO
DEFAULT_MODEL=gpt-4o
MAX_TOKENS=4096

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=                # Set in GitHub Environment secret: OPENAI_API_KEY
ANTHROPIC_API_KEY=

# ── Vector store (Qdrant staging collection / cloud-hosted) ───────────────────
QDRANT_URL=https://qdrant-staging.your-domain.com
QDRANT_API_KEY=                # GitHub secret: QDRANT_API_KEY_STAGING

# ── Cache (managed Redis, staging instance) ───────────────────────────────────
REDIS_URL=redis://staging-redis.your-domain.com:6379

# ── Object store (staging S3 / ADLS / GCS) ────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=llmops-staging-data  # separate bucket from production

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-staging.your-domain.com:4317
OTEL_SERVICE_NAME=llmops-staging

# ── Experiment tracking ────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=https://mlflow-staging.your-domain.com
WANDB_PROJECT=llmops-staging

# ── LiteLLM gateway ───────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=            # GitHub secret: LITELLM_MASTER_KEY_STAGING
LITELLM_PORT=4000

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-staging.your-domain.com:9092
KAFKA_TOPIC_INGESTION=llmops.ingestion.staging

# RAG behavior (tighten per application data/security requirements)
RAG_RETRIEVAL_MODE=hybrid       # vector | hybrid | graph_augmented | hybrid_graph
RAG_SECURITY_MODE=metadata_filtering
GRAPH_ENABLED=false
RERANKER_ENABLED=false

# ── Azure (staging service principal — read/write staging resources only) ──────
AZURE_TENANT_ID=               # GitHub secret: AZURE_TENANT_ID
AZURE_CLIENT_ID=               # GitHub secret: AZURE_CLIENT_ID_STAGING
AZURE_CLIENT_SECRET=           # GitHub secret: AZURE_CLIENT_SECRET_STAGING
                               # NOTE: In staging Container Apps, prefer Managed Identity
AZURE_OPENAI_ENDPOINT=https://llmops-staging-oai.openai.azure.com/
AZURE_OPENAI_API_KEY=          # GitHub secret: AZURE_OPENAI_API_KEY_STAGING
AZURE_AI_SEARCH_ENDPOINT=https://llmops-staging-search.search.windows.net
AZURE_AI_SEARCH_API_KEY=       # GitHub secret: AZURE_AI_SEARCH_API_KEY_STAGING
AZURE_STORAGE_ACCOUNT_NAME=llmopsstagingsa
AZURE_RESOURCE_GROUP=llmops-staging-rg
AZUREML_WORKSPACE_NAME=llmops-staging-aml
AZURE_APPINSIGHTS_CONNECTION_STRING=  # GitHub secret

# ── AWS (staging IAM role — limited to staging resources only) ─────────────────
# In CI, credentials come from GitHub OIDC → staging IAM role (not access keys)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
OPENSEARCH_ENDPOINT=https://llmops-staging-os.us-east-1.es.amazonaws.com
AWS_REDIS_URL=redis://llmops-staging-redis.abc123.cache.amazonaws.com:6379

# ── GCP (staging service account — limited to staging project) ────────────────
GCP_PROJECT_ID=your-gcp-project-staging
GCP_REGION=us-central1
# In CI, auth comes from GitHub OIDC → Workload Identity Federation (no JSON key)
VERTEX_MODEL_ID=gemini-1.5-pro-002
GCS_BUCKET=your-gcp-project-staging-llmops-staging-data
